<Panel id="root" x="10" y="10" width="300" height="200" color="#1A1A1AFF">
    <Label id="centeredLabel" x="150" y="20" width="200" height="30" textAlign="center">Centered text</Label>
    <Label id="rightLabel" x="10" y="60" width="200" height="30" textAlign="right">Right aligned</Label>
    <Panel id="anchoredPanel" x="150" y="100" width="100" height="40" anchor="center" color="#334455FF">
        <Label id="anchoredChild" x="0" y="4" textAlign="center">Anchored</Label>
    </Panel>
    <Label id="wrapLabel" x="10" y="150" width="150" height="60" wrap="true">This is a long label that should word wrap when it exceeds the element width</Label>
</Panel>
